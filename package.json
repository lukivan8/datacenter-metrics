{
  "private": true,
  "workspaces": [
    "datacenter-dashboard",
    "device-simulation",
    "ingestion-endpoint",
    "packages/*"
  ],
  "scripts": {
    "dev": "./scripts/dev-all.sh",
    "dev:api": "npm run dev -w ingestion-endpoint",
    "dev:web": "npm run dev -w datacenter-dashboard",
    "build:shared": "npm run build -w @lukivan8-datacenter/shared",
    "build:api": "npm run build -w ingestion-endpoint",
    "build:web": "npm run build -w datacenter-dashboard",
    "deploy": "./scripts/deploy.sh",
    "docker:local": "./scripts/docker-local.sh",
    "stop": "./scripts/stop.sh",
    "status": "./scripts/status.sh",
    "build": "npm run build:shared && npm run build:api && npm run build -w device-simulation && npm run build:web"
  }
}
