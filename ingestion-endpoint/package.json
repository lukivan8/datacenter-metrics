{
  "name": "ingestion-endpoint",
  "version": "1.0.0",
  "description": "Fastify telemetry ingestion backend for a live device telemetry dashboard",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:psql": "psql \"$DATABASE_URL\" -f db/schema.sql"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "pg": "^8.20.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.22.0",
    "typescript": "^6.0.3"
  }
}
