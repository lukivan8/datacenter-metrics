PORT=3000
HOST=0.0.0.0
DATABASE_URL=postgres://postgres:postgres@localhost:5432/telemetry

FLUSH_INTERVAL_MS=1000
FLUSH_BATCH_SIZE=500
MAX_INSERT_BATCH_SIZE=1000
MAX_BUFFER_SIZE=5000
DB_POOL_MAX=5

# Fastify/Pino logger options. Default level is info.
LOG_LEVEL=info
# Optional: override the default per-run log file: ./logs/ingestion-<timestamp>-<pid>.log
# LOG_FILE=./logs/ingestion.log

# Production dashboard static files served by the API process.
# STATIC_DIR=../datacenter-dashboard/dist
